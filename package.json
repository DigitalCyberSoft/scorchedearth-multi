{
  "name": "scorchedearth-multi",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Multiplayer fork of the Scorched Earth v1.5 browser port: a lobby + serverless P2P (WebRTC data channels signaled over Nostr relays) running lockstep over the deterministic engine.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "bash scripts/capped.sh vitest run",
    "test:uncapped": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "jsqr": "^1.4.0",
    "nostr-tools": "^2.23.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.8.0",
    "playwright": "^1.61.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^2.1.4"
  }
}
